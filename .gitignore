# Root .gitignore — cross-cutting rules.
# Each subproject (genai-be, genai-db, genai-fe) keeps its own .gitignore
# for build output and language-specific artifacts.

# ===== OS files =====
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
desktop.ini

# ===== Environment / secrets =====
.env
.env.*
!.env.example
!.env.template

# ===== Logs =====
*.log
logs/

# ===== IDE / editor =====
.idea/
.vscode/
*~
